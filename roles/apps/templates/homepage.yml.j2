name: homepage
services:
  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    networks:
     - backend
    environment:
     - GUID=1000
     - PGID=1000
     - HOMEPAGE_ALLOWED_HOSTS={{ domain }}
    volumes:
     - {{ storage_root }}/homepage/config:/app/config:Z
     - /var/run/docker.sock:/var/run/docker.sock:z

networks:
  backend:
    external: True
    name: homelab_backend
